# --- Core ---
FIRM_SQLITE_PATH=./data/firm.db
FIRM_AGENTS_CONFIG=./configs/agents.yaml
FIRM_OLLAMA_BASE_URL=http://localhost:11434

# Limit concurrent LLM calls (prevents self-inflicted overload)
FIRM_LLM_MAX_CONCURRENCY=2

# --- Alpaca (paper strongly recommended) ---
ALPACA_PAPER=1
ALPACA_KEY_ID=YOUR_KEY_ID
ALPACA_SECRET_KEY=YOUR_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Risk guardrails (USD) ---
FIRM_MAX_POSITION_USD=5000
FIRM_MAX_GROSS_EXPOSURE_USD=20000
